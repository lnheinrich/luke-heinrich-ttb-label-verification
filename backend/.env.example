CORS_ORIGINS=http://localhost:5173

# Used for vision model to extract label fields from images
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini

# Vision model request timeout in seconds
VISION_TIMEOUT_SECONDS=4.5

# Image preprocessing: longest side in pixels and JPEG re-encode quality
MAX_IMAGE_DIMENSION=1024
JPEG_QUALITY=75

# Maximum accepted upload size per image, in bytes (default 10 MiB)
MAX_IMAGE_BYTES=10485760

# Maximum concurrent vision requests while processing a batch
BATCH_CONCURRENCY=3

# Maximum number of labels accepted per batch request
MAX_BATCH_SIZE=10
